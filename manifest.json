{
  "manifest_version": 3,
  "name": "Job Application Copilot",
  "version": "1.0.0",
  "description": "Automate job applications using Alibaba PageAgent.",
  "action": {
    "default_popup": "index.html"
  },
  "side_panel": {
    "default_path": "options.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.jsx"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
